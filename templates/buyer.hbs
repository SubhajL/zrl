<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Buyer Quality Assurance Pack — {{laneId}}</title>
  <style>
    @page { size: A4; margin: 20mm; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 11px;
      color: #0F172A;
      line-height: 1.5;
      padding: 0;
    }
    h1 {
      font-size: 18px;
      color: #6C5CE7;
      margin-bottom: 4px;
    }
    .subtitle {
      font-size: 12px;
      color: #64748B;
      margin-bottom: 2px;
    }
    h2 {
      font-size: 14px;
      color: #0F172A;
      border-bottom: 2px solid #6C5CE7;
      padding-bottom: 4px;
      margin-top: 24px;
      margin-bottom: 8px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 8px 0;
    }
    th {
      background: #F1F5F9;
      text-align: left;
      padding: 6px 8px;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #475569;
      font-weight: 600;
    }
    td {
      padding: 6px 8px;
      border-bottom: 1px solid #E2E8F0;
      font-size: 11px;
    }
    tr:last-child td {
      border-bottom: none;
    }
    .mono {
      font-family: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;
      font-size: 10px;
    }
    .badge-pass {
      background: #DCFCE7;
      color: #15803D;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 600;
      display: inline-block;
    }
    .badge-fail {
      background: #FEE2E2;
      color: #B91C1C;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 600;
      display: inline-block;
    }
    .badge-missing {
      background: #FEF3C7;
      color: #B45309;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 600;
      display: inline-block;
    }
    .badge-present {
      background: #DCFCE7;
      color: #15803D;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 600;
      display: inline-block;
    }
    .badge-expired {
      background: #FEE2E2;
      color: #B91C1C;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 600;
      display: inline-block;
    }
    .header {
      border-bottom: 3px solid #6C5CE7;
      padding-bottom: 12px;
      margin-bottom: 8px;
    }
    .header-meta {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
    }
    .header-meta-item {
      font-size: 11px;
      color: #475569;
    }
    .header-meta-item strong {
      color: #0F172A;
    }
    .detail-table td:first-child {
      font-weight: 600;
      color: #475569;
      width: 160px;
      text-transform: uppercase;
      font-size: 10px;
      letter-spacing: 0.05em;
    }
    .no-data {
      color: #94A3B8;
      font-style: italic;
      padding: 12px 0;
    }
    .footer {
      margin-top: 32px;
      padding-top: 16px;
      border-top: 2px solid #6C5CE7;
      text-align: center;
    }
    .footer-brand {
      font-size: 12px;
      font-weight: 600;
      color: #6C5CE7;
      margin-bottom: 4px;
    }
    .footer-note {
      font-size: 10px;
      color: #64748B;
      margin-top: 4px;
    }
    .qr {
      display: inline-block;
      margin: 8px 0;
    }
    .hash {
      word-break: break-all;
    }
    .pack-type-label {
      display: inline-block;
      background: #6C5CE7;
      color: #FFFFFF;
      padding: 2px 10px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }

    /* Compliance Summary */
    .compliance-grid {
      display: flex;
      gap: 16px;
      margin: 12px 0;
      flex-wrap: wrap;
    }
    .compliance-card {
      flex: 1;
      min-width: 140px;
      border: 1px solid #E2E8F0;
      border-radius: 8px;
      padding: 12px 16px;
    }
    .compliance-card-label {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #64748B;
      font-weight: 600;
      margin-bottom: 6px;
    }
    .compliance-card-value {
      font-size: 16px;
      font-weight: 700;
    }
    .progress-bar-container {
      width: 100%;
      height: 8px;
      background: #E2E8F0;
      border-radius: 999px;
      overflow: hidden;
      margin-top: 6px;
    }
    .progress-bar-fill {
      height: 100%;
      border-radius: 999px;
    }
    .cert-list {
      list-style: none;
      padding: 0;
      margin: 8px 0;
    }
    .cert-list li {
      padding: 4px 0;
      font-size: 11px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .cert-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      font-size: 11px;
      font-weight: 700;
    }
    .cert-icon-pass {
      background: #DCFCE7;
      color: #15803D;
    }
    .cert-icon-fail {
      background: #FEE2E2;
      color: #B91C1C;
    }
    .cert-icon-missing {
      background: #FEF3C7;
      color: #B45309;
    }
    .sla-message {
      font-size: 11px;
      margin-top: 8px;
      padding: 8px 12px;
      border-radius: 6px;
    }
    .sla-message-pass {
      background: #F0FDF4;
      color: #15803D;
      border: 1px solid #BBF7D0;
    }
    .sla-message-fail {
      background: #FEF2F2;
      color: #B91C1C;
      border: 1px solid #FECACA;
    }
  </style>
</head>
<body>

  <!-- Header -->
  <div class="header">
    <div class="pack-type-label">{{packType}}</div>
    <h1>ZERO-REJECT EXPORT LANE</h1>
    <div class="subtitle">Buyer Quality Assurance Pack</div>
    <div class="header-meta">
      <div class="header-meta-item">
        Lane ID: <strong class="mono">{{laneId}}</strong>
      </div>
      <div class="header-meta-item">
        Generated: <strong>{{generatedAt}}</strong>
      </div>
    </div>
  </div>

  <!-- Section 1: Product Summary -->
  <h2>1. Product Summary</h2>
  <table class="detail-table">
    <tr>
      <td>Product</td>
      <td>{{product}}</td>
    </tr>
    <tr>
      <td>Variety</td>
      <td>{{variety}}</td>
    </tr>
    <tr>
      <td>Quantity (kg)</td>
      <td>{{quantity}}</td>
    </tr>
    <tr>
      <td>Grade</td>
      <td>{{grade}}</td>
    </tr>
    <tr>
      <td>Origin</td>
      <td>{{origin}}</td>
    </tr>
  </table>

  <!-- Section 2: Compliance Summary -->
  <h2>2. Compliance Summary</h2>
  <div class="compliance-grid">
    <div class="compliance-card">
      <div class="compliance-card-label">Completeness</div>
      <div class="compliance-card-value" style="color: #6C5CE7;">{{completeness}}%</div>
      <div class="progress-bar-container">
        <div class="progress-bar-fill" style="width: {{completeness}}%; background: #6C5CE7;"></div>
      </div>
    </div>
    <div class="compliance-card">
      <div class="compliance-card-label">MRL Status</div>
      <div style="margin-top: 4px;">
        {{#if (eq status "PASS")}}
          <span class="badge-pass" style="font-size: 14px; padding: 4px 14px;">PASS</span>
        {{else}}
          <span class="badge-fail" style="font-size: 14px; padding: 4px 14px;">FAIL</span>
        {{/if}}
      </div>
    </div>
  </div>

  <div style="margin-top: 12px;">
    <div class="compliance-card-label">Key Certifications</div>
    {{#if checklistItems}}
    <ul class="cert-list">
      {{#each checklistItems}}
      <li>
        {{#if (eq this.status "PRESENT")}}
          <span class="cert-icon cert-icon-pass">&#10003;</span>
        {{else if (eq this.status "MISSING")}}
          <span class="cert-icon cert-icon-missing">&#8212;</span>
        {{else if (eq this.status "EXPIRED")}}
          <span class="cert-icon cert-icon-fail">&#10007;</span>
        {{else}}
          <span class="cert-icon cert-icon-missing">?</span>
        {{/if}}
        <span>{{this.label}}</span>
        {{#if (eq this.status "MISSING")}}
          <span class="badge-missing" style="margin-left: 4px;">MISSING</span>
        {{else if (eq this.status "EXPIRED")}}
          <span class="badge-expired" style="margin-left: 4px;">EXPIRED</span>
        {{/if}}
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="no-data">No certification data available.</p>
    {{/if}}
  </div>

  <!-- Section 3: Cold-Chain Summary -->
  <h2>3. Cold-Chain Summary</h2>
  <table class="detail-table">
    <tr>
      <td>SLA Status</td>
      <td>
        {{#if (eq slaStatus "PASS")}}
          <span class="badge-pass">PASS</span>
        {{else if (eq slaStatus "FAIL")}}
          <span class="badge-fail">FAIL</span>
        {{else}}
          <span class="badge-missing">{{slaStatus}}</span>
        {{/if}}
      </td>
    </tr>
  </table>
  {{#if (eq slaStatus "PASS")}}
  <div class="sla-message sla-message-pass">
    Temperature maintained within specification throughout the supply chain.
  </div>
  {{else}}
  <div class="sla-message sla-message-fail">
    Temperature excursions detected. {{excursionCount}} excursion(s) recorded during transport. Review cold-chain data for details.
  </div>
  {{/if}}

  <!-- Section 4: Chain of Custody -->
  <h2>4. Chain of Custody</h2>
  {{#if checkpoints}}
  <table>
    <thead>
      <tr>
        <th>Seq</th>
        <th>Location</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      {{#each checkpoints}}
      <tr>
        <td>{{this.sequence}}</td>
        <td>{{this.location}}</td>
        <td>
          {{#if (eq this.status "PASS")}}
            <span class="badge-pass">PASS</span>
          {{else if (eq this.status "FAIL")}}
            <span class="badge-fail">FAIL</span>
          {{else}}
            <span class="badge-missing">{{this.status}}</span>
          {{/if}}
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <p class="no-data">No checkpoint data available.</p>
  {{/if}}

  <!-- Footer -->
  <div class="footer">
    <div class="qr">
      {{#if qrCodeDataUrl}}
      <img src="{{qrCodeDataUrl}}" width="120" height="120" alt="Verification QR Code">
      {{/if}}
    </div>
    <div class="footer-brand">Verified by ZRL &mdash; Zero-Reject Export Lane</div>
    <div style="margin-top: 8px;">
      <span style="font-size: 10px; color: #475569;">Verification Reference:</span><br>
      <span class="mono hash">{{verificationReference}}</span>
    </div>
    <div class="footer-note">
      This document is tamper-evident. Scan QR code to verify.
    </div>
  </div>

</body>
</html>
