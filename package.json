{
  "name": "zrl",
  "version": "0.1.0",
  "description": "Zero-Reject Export Lane — audit-grade evidence orchestration for Thai fruit exporters",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build && npm run build:frontend",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "jest",
    "test:unit": "jest --testPathPattern=src",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:backend": "jest --config ./test/jest-e2e.json",
    "test:e2e:playwright": "cd frontend && npm run test:e2e",
    "test:e2e:playwright:list": "cd frontend && npm run test:e2e:list",
    "test:perf:smoke": "bash scripts/run-k6-suite.sh",
    "test:perf:local": "bash scripts/run-local-k6-smoke.sh",
    "test:perf:lane": "K6_SCRIPTS='performance/k6/lane-crud.js' bash scripts/run-k6-suite.sh",
    "test:perf:upload": "K6_SCRIPTS='performance/k6/evidence-upload.js' bash scripts/run-k6-suite.sh",
    "test:perf:proof-pack": "K6_SCRIPTS='performance/k6/proof-pack.js' bash scripts/run-k6-suite.sh",
    "security:zap": "bash scripts/run-zap-baseline.sh",
    "security:zap:local": "bash scripts/run-local-zap-smoke.sh",
    "check:prisma-runtime": "bash scripts/check-prisma-runtime.sh",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1017.0",
    "@aws-sdk/client-ses": "^3.1018.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/websockets": "^11.1.17",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "^8.20.0",
    "@types/speakeasy": "^2.0.10",
    "bcrypt": "^6.0.0",
    "exifr": "^7.1.3",
    "handlebars": "^4.7.8",
    "jszip": "^3.10.1",
    "pg": "^8.20.0",
    "puppeteer-core": "^24.40.0",
    "qrcode": "^1.5.4",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.5.0",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
