generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────

enum UserRole {
  EXPORTER
  PARTNER
  ADMIN
  AUDITOR

  @@map("user_role")
}

enum LaneStatus {
  CREATED
  EVIDENCE_COLLECTING
  VALIDATED
  PACKED
  CLOSED
  INCOMPLETE
  CLAIM_DEFENSE
  DISPUTE_RESOLVED
  ARCHIVED

  @@map("lane_status")
}

enum ProductType {
  MANGO
  DURIAN
  MANGOSTEEN
  LONGAN

  @@map("product_type")
}

enum DestinationMarket {
  JAPAN
  CHINA
  KOREA
  EU

  @@map("destination_market")
}

enum TransportMode {
  AIR
  SEA
  TRUCK

  @@map("transport_mode")
}

enum ArtifactType {
  MRL_TEST
  VHT_CERT
  PHYTO_CERT
  CHECKPOINT_PHOTO
  TEMP_DATA
  HANDOFF_SIGNATURE
  INVOICE
  GAP_CERT

  @@map("artifact_type")
}

enum ArtifactSource {
  UPLOAD
  PARTNER_API
  CAMERA

  @@map("artifact_source")
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FAILED

  @@map("verification_status")
}

enum CheckpointStatus {
  PENDING
  COMPLETED
  OVERDUE

  @@map("checkpoint_status")
}

enum PackType {
  REGULATOR
  BUYER
  DEFENSE

  @@map("pack_type")
}

enum PackStatus {
  GENERATING
  READY
  FAILED

  @@map("pack_status")
}

enum ProofPackJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED

  @@map("proof_pack_job_status")
}

enum AuditAction {
  UPLOAD
  SIGN
  GENERATE
  VERIFY
  CREATE
  UPDATE
  DELETE

  @@map("audit_action")
}

enum AuditEntityType {
  LANE
  ARTIFACT
  CHECKPOINT
  PROOF_PACK
  RULE_SET
  SUBSTANCE

  @@map("audit_entity_type")
}

enum Grade {
  PREMIUM
  A
  B

  @@map("grade")
}

enum ColdChainMode {
  MANUAL
  LOGGER
  TELEMETRY

  @@map("cold_chain_mode")
}

enum ExcursionSeverity {
  MINOR
  MODERATE
  SEVERE
  CRITICAL

  @@map("excursion_severity")
}

enum ExcursionDirection {
  LOW
  HIGH

  @@map("excursion_direction")
}

enum ExcursionType {
  CHILLING
  HEAT

  @@map("excursion_type")
}

enum RiskLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW

  @@map("risk_level")
}

enum NotificationType {
  RULE_CHANGE
  EXCURSION_ALERT
  CERTIFICATION_EXPIRY
  MISSING_DOCUMENT
  PACK_GENERATED
  CLAIM_FILED

  @@map("notification_type")
}

enum PrivacyConsentType {
  MARKETING_COMMUNICATIONS

  @@map("privacy_consent_type")
}

enum PrivacyRequestType {
  ACCESS
  CORRECTION
  DELETION
  OBJECTION
  PORTABILITY
  WITHDRAW_CONSENT

  @@map("privacy_request_type")
}

enum PrivacyRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED

  @@map("privacy_request_status")
}

enum DataExportStatus {
  READY
  FAILED
  EXPIRED

  @@map("data_export_status")
}

enum DisputeType {
  CUSTOMS_REJECTION
  QUALITY_CLAIM
  INSURANCE_CLAIM
  GRADE_DISPUTE
  CARGO_DAMAGE

  @@map("dispute_type")
}

enum DisputeStatus {
  OPEN
  INVESTIGATING
  DEFENSE_SUBMITTED
  RESOLVED

  @@map("dispute_status")
}

// ─── Models ─────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String   @map("password_hash")
  role           UserRole
  companyName    String?  @map("company_name")
  mfaEnabled     Boolean  @default(false) @map("mfa_enabled")
  totpSecret     String?  @map("totp_secret")
  sessionVersion Int      @default(0) @map("session_version")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  apiKeys                   ApiKey[]
  passwordResetRequests     PasswordResetRequest[]
  lanes                     Lane[]
  uploadedArtifacts         EvidenceArtifact[]
  generatedPacks            ProofPack[]
  notifications             Notification[]
  notificationPreferences   NotificationPreference[]
  notificationChannelTarget NotificationChannelTarget?
  privacyConsentEvents      PrivacyConsentEvent[]
  privacyRequests           PrivacyRequest[]           @relation("PrivacyRequestRequester")
  processedPrivacyRequests  PrivacyRequest[]           @relation("PrivacyRequestProcessedBy")
  dataExportRequests        DataExportRequest[]
  reportedPrivacyBreaches   PrivacyBreachIncident[]    @relation("PrivacyBreachReportedBy")

  @@map("users")
}

model ApiKey {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  keyHash     String    @map("key_hash")
  name        String
  scopes      String[]
  ipWhitelist String[]  @map("ip_whitelist")
  expiresAt   DateTime? @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("api_keys")
}

model PasswordResetRequest {
  id        String    @id @default(uuid())
  email     String
  userId    String?   @map("user_id")
  tokenHash String?   @unique @map("token_hash")
  expiresAt DateTime? @map("expires_at")
  usedAt    DateTime? @map("used_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([email, createdAt])
  @@map("password_reset_requests")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  laneId    String?          @map("lane_id")
  type      NotificationType
  title     String
  message   String
  data      Json?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  lane Lane? @relation(fields: [laneId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

model PrivacyConsentEvent {
  id          String             @id @default(uuid())
  userId      String             @map("user_id")
  consentType PrivacyConsentType @map("consent_type")
  granted     Boolean
  source      String
  createdAt   DateTime           @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType, createdAt])
  @@map("privacy_consent_events")
}

model PrivacyRequest {
  id                String               @id @default(uuid())
  userId            String               @map("user_id")
  requestType       PrivacyRequestType   @map("request_type")
  status            PrivacyRequestStatus @default(PENDING)
  reason            String?
  details           Json?
  dueAt             DateTime             @map("due_at")
  completedAt       DateTime?            @map("completed_at")
  processedByUserId String?              @map("processed_by_user_id")
  resolution        Json?
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  user        User  @relation("PrivacyRequestRequester", fields: [userId], references: [id], onDelete: Cascade)
  processedBy User? @relation("PrivacyRequestProcessedBy", fields: [processedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, dueAt])
  @@index([processedByUserId])
  @@map("privacy_requests")
}

model PrivacyBreachIncident {
  id                     String    @id @default(uuid())
  reportedByUserId       String    @map("reported_by_user_id")
  summary                String
  description            String
  affectedUserIds        String[]  @map("affected_user_ids")
  detectedAt             DateTime  @map("detected_at")
  occurredAt             DateTime? @map("occurred_at")
  pdpaOfficeNotifiedAt   DateTime? @map("pdpa_office_notified_at")
  dataSubjectsNotifiedAt DateTime? @map("data_subjects_notified_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  reportedBy User @relation("PrivacyBreachReportedBy", fields: [reportedByUserId], references: [id], onDelete: Restrict)

  @@index([reportedByUserId, createdAt])
  @@index([createdAt])
  @@map("privacy_breach_incidents")
}

model DataExportRequest {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  status      DataExportStatus @default(READY)
  fileName    String           @map("file_name")
  contentType String           @map("content_type")
  zipData     Bytes            @map("zip_data")
  exportedAt  DateTime         @default(now()) @map("exported_at")
  expiresAt   DateTime?        @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, exportedAt])
  @@map("data_export_requests")
}

model NotificationPreference {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  type         NotificationType
  inAppEnabled Boolean          @default(true) @map("in_app_enabled")
  emailEnabled Boolean          @default(false) @map("email_enabled")
  pushEnabled  Boolean          @default(false) @map("push_enabled")
  lineEnabled  Boolean          @default(false) @map("line_enabled")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("notification_preferences")
}

model NotificationChannelTarget {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  lineUserId   String?  @map("line_user_id")
  pushEndpoint String?  @map("push_endpoint")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_channel_targets")
}

model CertificationAlertDelivery {
  id             String       @id @default(uuid())
  laneId         String       @map("lane_id")
  artifactId     String       @map("artifact_id")
  artifactType   ArtifactType @map("artifact_type")
  alertCode      String       @map("alert_code")
  warningDays    Int?         @map("warning_days")
  expiresAt      DateTime?    @map("expires_at")
  notificationId String?      @unique @map("notification_id")
  deliveryStatus String       @map("delivery_status")
  claimedAt      DateTime     @map("claimed_at")
  deliveredAt    DateTime?    @map("delivered_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([laneId, artifactId, alertCode])
  @@index([deliveryStatus, claimedAt])
  @@map("certification_alert_deliveries")
}

model Lane {
  id                            String            @id @default(uuid())
  laneId                        String            @unique @map("lane_id")
  exporterId                    String            @map("exporter_id")
  status                        LaneStatus        @default(CREATED)
  productType                   ProductType       @map("product_type")
  destinationMarket             DestinationMarket @map("destination_market")
  completenessScore             Decimal           @default(0) @map("completeness_score") @db.Decimal(5, 2)
  coldChainMode                 ColdChainMode?    @map("cold_chain_mode")
  statusChangedAt               DateTime          @default(now()) @map("status_changed_at")
  coldChainDeviceId             String?           @map("cold_chain_device_id")
  coldChainDataFrequencySeconds Int?              @map("cold_chain_data_frequency_seconds")
  coldChainSlaBreachedAt        DateTime?         @map("cold_chain_sla_breached_at")
  createdAt                     DateTime          @default(now()) @map("created_at")
  updatedAt                     DateTime          @updatedAt @map("updated_at")

  // Relations
  exporter            User                 @relation(fields: [exporterId], references: [id], onDelete: Restrict)
  batch               Batch?
  route               Route?
  ruleSnapshot        RuleSnapshot?
  checkpoints         Checkpoint[]
  artifacts           EvidenceArtifact[]
  proofPacks          ProofPack[]
  notifications       Notification[]
  temperatureReadings TemperatureReading[]
  excursions          Excursion[]
  disputes            Dispute[]

  @@map("lanes")
}

model Dispute {
  id              String        @id @default(uuid())
  laneId          String        @map("lane_id")
  type            DisputeType
  description     String
  claimant        String
  status          DisputeStatus @default(OPEN)
  financialImpact Decimal?      @map("financial_impact") @db.Decimal(12, 2)
  resolutionNotes String?       @map("resolution_notes")
  defensePackId   String?       @map("defense_pack_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  resolvedAt      DateTime?     @map("resolved_at")

  lane Lane @relation(fields: [laneId], references: [id], onDelete: Restrict)

  @@index([laneId])
  @@map("disputes")
}

model EmissionFactor {
  id            String            @id @default(uuid())
  product       ProductType
  market        DestinationMarket
  transportMode TransportMode     @map("transport_mode")
  co2ePerKg     Decimal           @map("co2e_per_kg") @db.Decimal(10, 4)
  source        String
  lastUpdated   DateTime          @map("last_updated") @db.Date
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@unique([product, market, transportMode])
  @@map("emission_factors")
}

model FruitProfile {
  id                 String      @id @default(uuid())
  productType        ProductType @unique @map("product_type")
  optimalMinC        Decimal     @map("optimal_min_c") @db.Decimal(5, 2)
  optimalMaxC        Decimal     @map("optimal_max_c") @db.Decimal(5, 2)
  chillingThresholdC Decimal?    @map("chilling_threshold_c") @db.Decimal(5, 2)
  heatThresholdC     Decimal     @map("heat_threshold_c") @db.Decimal(5, 2)
  shelfLifeMinDays   Int         @map("shelf_life_min_days")
  shelfLifeMaxDays   Int         @map("shelf_life_max_days")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  @@map("fruit_profiles")
}

model TemperatureReading {
  id           String   @id @default(uuid())
  laneId       String   @map("lane_id")
  recordedAt   DateTime @map("recorded_at")
  temperatureC Decimal  @map("temperature_c") @db.Decimal(5, 2)
  deviceId     String?  @map("device_id")
  createdAt    DateTime @default(now()) @map("created_at")

  lane Lane @relation(fields: [laneId], references: [id], onDelete: Restrict)

  @@index([laneId, recordedAt])
  @@map("temperature_readings")
}

model Excursion {
  id                     String             @id @default(uuid())
  laneId                 String             @map("lane_id")
  startedAt              DateTime           @map("started_at")
  endedAt                DateTime?          @map("ended_at")
  ongoing                Boolean            @default(false)
  durationMinutes        Int                @map("duration_minutes")
  severity               ExcursionSeverity
  direction              ExcursionDirection
  excursionType          ExcursionType      @map("excursion_type")
  thresholdC             Decimal            @map("threshold_c") @db.Decimal(5, 2)
  minObservedC           Decimal            @map("min_observed_c") @db.Decimal(5, 2)
  maxObservedC           Decimal            @map("max_observed_c") @db.Decimal(5, 2)
  maxDeviationC          Decimal            @map("max_deviation_c") @db.Decimal(5, 2)
  shelfLifeImpactPercent Int                @map("shelf_life_impact_percent")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  lane Lane @relation(fields: [laneId], references: [id], onDelete: Restrict)

  @@index([laneId, startedAt])
  @@map("excursions")
}

model Batch {
  id             String      @id @default(uuid())
  laneId         String      @unique @map("lane_id")
  batchId        String      @unique @map("batch_id")
  product        ProductType
  variety        String?
  quantityKg     Decimal     @map("quantity_kg") @db.Decimal(10, 2)
  originProvince String      @map("origin_province")
  harvestDate    DateTime    @map("harvest_date") @db.Date
  grade          Grade

  // Relations
  lane Lane @relation(fields: [laneId], references: [id])

  @@map("batches")
}

model Route {
  id                    String        @id @default(uuid())
  laneId                String        @unique @map("lane_id")
  transportMode         TransportMode @map("transport_mode")
  carrier               String?
  originGps             Json?         @map("origin_gps")
  destinationGps        Json?         @map("destination_gps")
  estimatedTransitHours Int?          @map("estimated_transit_hours")

  // Relations
  lane Lane @relation(fields: [laneId], references: [id])

  @@map("routes")
}

model Checkpoint {
  id             String           @id @default(uuid())
  laneId         String           @map("lane_id")
  sequence       Int
  locationName   String           @map("location_name")
  gpsLat         Decimal?         @map("gps_lat") @db.Decimal(10, 7)
  gpsLng         Decimal?         @map("gps_lng") @db.Decimal(10, 7)
  timestamp      DateTime?
  temperature    Decimal?         @db.Decimal(5, 2)
  signatureHash  String?          @map("signature_hash") @db.Char(64)
  signerName     String?          @map("signer_name")
  conditionNotes String?          @map("condition_notes")
  status         CheckpointStatus @default(PENDING)

  // Relations
  lane      Lane               @relation(fields: [laneId], references: [id])
  artifacts EvidenceArtifact[]

  @@unique([laneId, sequence])
  @@map("checkpoints")
}

model EvidenceArtifact {
  id                 String             @id @default(uuid())
  laneId             String             @map("lane_id")
  artifactType       ArtifactType       @map("artifact_type")
  fileName           String             @map("file_name")
  mimeType           String             @map("mime_type")
  fileSizeBytes      Int                @map("file_size_bytes")
  filePath           String             @map("file_path")
  contentHash        String             @map("content_hash") @db.Char(64)
  source             ArtifactSource     @default(UPLOAD)
  checkpointId       String?            @map("checkpoint_id")
  issuer             String?
  issuedAt           DateTime?          @map("issued_at")
  uploadedBy         String             @map("uploaded_by")
  uploadedAt         DateTime           @default(now()) @map("uploaded_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  metadata           Json?
  deletedAt          DateTime?          @map("deleted_at")

  // Relations
  lane        Lane           @relation(fields: [laneId], references: [id], onDelete: Restrict)
  checkpoint  Checkpoint?    @relation(fields: [checkpointId], references: [id], onDelete: SetNull)
  uploader    User           @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)
  sourceLinks ArtifactLink[] @relation("SourceArtifact")
  targetLinks ArtifactLink[] @relation("TargetArtifact")

  @@index([laneId, artifactType])
  @@index([laneId, verificationStatus])
  @@index([checkpointId])
  @@map("evidence_artifacts")
}

model ArtifactLink {
  id               String @id @default(uuid())
  sourceArtifactId String @map("source_artifact_id")
  targetArtifactId String @map("target_artifact_id")
  relationshipType String @map("relationship_type")

  // Relations
  sourceArtifact EvidenceArtifact @relation("SourceArtifact", fields: [sourceArtifactId], references: [id])
  targetArtifact EvidenceArtifact @relation("TargetArtifact", fields: [targetArtifactId], references: [id])

  @@unique([sourceArtifactId, targetArtifactId])
  @@map("artifact_links")
}

model ProofPack {
  id           String     @id @default(uuid())
  laneId       String     @map("lane_id")
  packType     PackType   @map("pack_type")
  version      Int        @default(1)
  status       PackStatus @default(GENERATING)
  contentHash  String?    @map("content_hash") @db.Char(64)
  filePath     String?    @map("file_path")
  errorMessage String?    @map("error_message")
  generatedAt  DateTime   @default(now()) @map("generated_at")
  generatedBy  String     @map("generated_by")
  recipient    String?

  // Relations
  lane      Lane          @relation(fields: [laneId], references: [id], onDelete: Restrict)
  generator User          @relation(fields: [generatedBy], references: [id], onDelete: Restrict)
  job       ProofPackJob?

  @@map("proof_packs")
}

model ProofPackJob {
  id             String             @id @default(uuid())
  proofPackId    String             @unique @map("proof_pack_id")
  status         ProofPackJobStatus @default(QUEUED)
  payload        Json
  attemptCount   Int                @default(0) @map("attempt_count")
  lastError      String?            @map("last_error")
  availableAt    DateTime           @default(now()) @map("available_at")
  leasedAt       DateTime?          @map("leased_at")
  leaseExpiresAt DateTime?          @map("lease_expires_at")
  completedAt    DateTime?          @map("completed_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @default(now()) @map("updated_at")

  proofPack ProofPack @relation(fields: [proofPackId], references: [id], onDelete: Restrict)

  @@index([status, availableAt])
  @@index([status, leaseExpiresAt])
  @@map("proof_pack_jobs")
}

model AuditEntry {
  id          String          @id @default(uuid())
  timestamp   DateTime        @default(now())
  actor       String
  action      AuditAction
  entityType  AuditEntityType @map("entity_type")
  entityId    String          @map("entity_id")
  payloadHash String          @map("payload_hash") @db.Char(64)
  prevHash    String          @map("prev_hash") @db.Char(64)
  entryHash   String          @map("entry_hash") @db.Char(64)

  snapshot AuditEntrySnapshot?

  @@index([entityId])
  @@index([timestamp])
  @@map("audit_entries")
}

model AuditEntrySnapshot {
  auditEntryId String @id @map("audit_entry_id")
  payload      Json

  auditEntry AuditEntry @relation(fields: [auditEntryId], references: [id], onDelete: Restrict)

  @@map("audit_entry_snapshots")
}

model RuleSnapshot {
  id            String            @id @default(uuid())
  laneId        String            @unique @map("lane_id")
  market        DestinationMarket
  product       ProductType
  version       Int               @default(1)
  rules         Json
  effectiveDate DateTime          @map("effective_date") @db.Date
  createdAt     DateTime          @default(now()) @map("created_at")

  // Relations
  lane Lane @relation(fields: [laneId], references: [id])

  @@map("rule_snapshots")
}

model Substance {
  id              String            @id @default(uuid())
  market          DestinationMarket
  name            String
  cas             String?
  thaiMrl         Decimal?          @map("thai_mrl") @db.Decimal(10, 4)
  destinationMrl  Decimal           @map("destination_mrl") @db.Decimal(10, 4)
  stringencyRatio Decimal?          @map("stringency_ratio") @db.Decimal(10, 2)
  riskLevel       RiskLevel?        @map("risk_level")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@unique([market, name])
  @@map("substances")
}

model RuleSet {
  id            String            @id @default(uuid())
  market        DestinationMarket
  product       ProductType
  version       Int
  effectiveDate DateTime          @map("effective_date") @db.Date
  sourcePath    String?           @map("source_path")
  rules         Json
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  versions RuleVersion[]

  @@unique([market, product])
  @@map("rule_sets")
}

model RuleVersion {
  id             String            @id @default(uuid())
  ruleSetId      String            @map("rule_set_id")
  market         DestinationMarket
  product        ProductType
  version        Int
  changesSummary String            @map("changes_summary")
  rules          Json
  changedAt      DateTime          @default(now()) @map("changed_at")

  ruleSet RuleSet @relation(fields: [ruleSetId], references: [id], onDelete: Restrict)

  @@unique([ruleSetId, version])
  @@index([market, product])
  @@map("rule_versions")
}
